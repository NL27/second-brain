# Copy this file to .env and fill in the keys for the providers you want to use.
# Local models (Ollama) need NO key. Cloud keys are only needed for the
# providers you actually enable in config.yaml / the model registry.

# --- Cloud LLM providers (all optional) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=
# Qwen / DashScope
DASHSCOPE_API_KEY=
# Google Gemini
GEMINI_API_KEY=

# --- Local model server (Ollama) ---
# Default Ollama endpoint. Change only if you run it elsewhere.
OLLAMA_HOST=http://localhost:11434

# --- Behavior overrides (optional; config.yaml is the source of truth) ---
# Force every destructive action to require confirmation regardless of rules.
# BRAIN_REQUIRE_APPROVAL=1
# Run without executing any real actions (plan + log only).
# BRAIN_DRY_RUN=1
